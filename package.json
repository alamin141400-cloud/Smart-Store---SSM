{
  "name": "smartstores-pro",
  "version": "3.3.0",
  "main": "src/main.js",
  "type": "commonjs",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --publish never"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.smartstore.ssm",
    "files": [
      "src/**",
      "renderer/**",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "publish": null
  }
}
